# Copy to .env and fill in real values. .env is gitignored.
# .env.example IS checked in — keep keys in sync but never put real values here.

# ─── LLM providers ─────────────────────────────────────────────
# Claude (Opus 4.7 / Sonnet 4.6 / Haiku 4.5 — stakes-tiered per plan).
ANTHROPIC_API_KEY=

# OpenAI Whisper for transcription (Phase 1 ingestion).
OPENAI_API_KEY=

# ─── Market data ───────────────────────────────────────────────
# Polygon.io Developer tier (baseline). Advanced tier upgrade deferred
# pending Phase 5 Gate 6 — do NOT enable L2 code paths yet.
POLYGON_API_KEY=

# ─── Broker ────────────────────────────────────────────────────
# Alpaca: same keys work for paper and live, ALPACA_BASE_URL switches envs.
# Paper: https://paper-api.alpaca.markets
# Live:  https://api.alpaca.markets  ← Phase 7 only
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── Discord ingestion (Phase 1 handler) ───────────────────────
# Pasted-text approach (resolved 2026-04-22) — user pastes from
# personal account; no token, no throwaway, no DiscordChatExporter.
# No env vars needed.

# ─── App config ────────────────────────────────────────────────
# structlog level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# SQLite path (relative to repo root). Kept in .gitignore.
DB_PATH=./data/research.db

# Where raw ingested content lives (videos, transcripts, exports).
# Large and gitignored.
CONTENT_DIR=./content
